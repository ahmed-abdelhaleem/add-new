# Anthropic API key powers the ACE conversational layer.
# When unset, ACE falls back to a deterministic local responder so the
# app still runs in development.
ANTHROPIC_API_KEY=

# Override the model used for ACE. Defaults to claude-sonnet-4-6.
ACE_MODEL=claude-sonnet-4-6

# Path to the SQLite database file. Defaults to ./momentum.db.
MOMENTUM_DB_PATH=
