# Anthropic API key powers the ACE conversational layer.
# When unset, ACE falls back to a deterministic local responder so the
# app still runs in development.
ANTHROPIC_API_KEY=

# Override the model used for ACE. Defaults to claude-sonnet-4-6.
ACE_MODEL=claude-sonnet-4-6

# Path to the SQLite database file.
# Defaults: ./momentum.db locally, /data/momentum.db in production (Railway).
# On Railway, attach a Volume mounted at /data for the DB to persist.
MOMENTUM_DB_PATH=

# Railway sets PORT automatically; you don't need to set it.
# PORT=3000
